PORT=4000
NODE_ENV=development

# Cadena de conexión PostgreSQL (Neon)
# Pooled (con pgbouncer=true para Prisma):
# DATABASE_URL="postgresql://usuario:password@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# Direct (sin pooler, para migrations):
# DIRECT_URL="postgresql://usuario:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Local:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/puku_puku_crm?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/puku_puku_crm?schema=public"

# Seguridad
JWT_SECRET="cambia_esto_por_un_secreto_largo_y_aleatorio"
JWT_EXPIRES_IN="8h"
CORS_ORIGIN="http://localhost:5173,https://puku-puku-crm-web.onrender.com"
JWT_REFRESH_SECRET="cambia_esto_por_otro_secreto_para_refresh"
JWT_REFRESH_EXPIRES_IN="7d"

# Regla de negocio (APF3): días de inactividad para marcar churn_label = 1
CHURN_INACTIVITY_DAYS=30

# ML Training: ruta al ejecutable de Python (por defecto "python")
PYTHON_PATH=python
