// =============================================================
// PUKU PUKU CRM — Schema de base de datos
// Mapea directamente las Pantallas 1-3 y los User Stories del
// Product Backlog del APF2 (US01-US09) a tablas relacionales.
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

enum CanalOrigen {
  PRESENCIAL
  WHATSAPP
  INSTAGRAM
  RAPPI
  PEDIDOSYA
}

enum EstadoInteraccion {
  RESUELTO
  EN_SEGUIMIENTO
  PENDIENTE
}

enum Satisfaccion {
  SATISFECHO
  NEUTRO
  INSATISFECHO
}

enum RolUsuario {
  COLABORADOR
  ADMINISTRADOR
  GERENTE
}

/// Personal de Puku Puku que usa el panel (colaboradores, admins, gerencia)
model Usuario {
  id               String        @id @default(uuid())
  nombre           String
  email            String        @unique
  passwordHash     String
  rol              RolUsuario    @default(COLABORADOR)
  twoFactorEnabled Boolean       @default(false) // DoD-04 / Ley 29733: 2FA en cuentas admin
  activo           Boolean       @default(true)
  createdAt        DateTime      @default(now())
  interacciones    Interaccion[] @relation("ColaboradorInteracciones")

  @@map("usuarios")
}

/// Pantalla 1 — Búsqueda y registro inicial del cliente (US01, US08)
model Cliente {
  id                     String        @id @default(uuid())
  nombreCompleto         String
  telefono               String        @unique
  canalOrigen            CanalOrigen
  productoFavorito       String?
  restriccionesAlergias  String?
  // --- Cumplimiento Ley N.° 29733 (US08) ---
  consentimientoLey29733 Boolean       @default(false)
  fechaConsentimiento    DateTime?
  createdAt              DateTime      @default(now())
  updatedAt               DateTime     @updatedAt
  interacciones          Interaccion[]

  @@index([telefono])
  @@index([nombreCompleto])
  @@map("clientes")
}

/// Pantalla 2 (historial) + Pantalla 3 (cierre post-atención)
/// US02, US03, US05, US09
model Interaccion {
  id                   String            @id @default(uuid())
  cliente              Cliente           @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  clienteId            String
  canal                CanalOrigen
  resumenPedido        String?
  montoSoles           Decimal?          @db.Decimal(10, 2) // alimenta ticket_promedio_soles (APF3)
  colaborador          Usuario           @relation("ColaboradorInteracciones", fields: [colaboradorId], references: [id])
  colaboradorId        String
  estado               EstadoInteraccion @default(PENDIENTE)
  // --- Campos de cierre (Pantalla 3, completar en ≤45s) ---
  actualizoPreferencia Boolean           @default(false)
  observacion          String?
  satisfaccion         Satisfaccion?
  fecha                DateTime          @default(now())
  cerradaEn            DateTime?

  @@index([clienteId])
  @@index([fecha])
  @@map("interacciones")
}

/// Auditoría de acciones del panel (Ley N.° 29733, art. 13°)
/// Registro inmutable de quién hizo qué y cuándo.
model AuditLog {
  id        String   @id @default(uuid())
  usuarioId String?
  accion    String   // ej. "CLIENTE.CREAR", "INTERACCION.CERRAR", "USUARIO.LOGIN"
  detalle   String?  // JSON con payload relevante (nunca passwords)
  ip        String?
  createdAt DateTime @default(now())

  @@index([usuarioId])
  @@index([accion])
  @@index([createdAt])
  @@map("audit_logs")
}

/// ML Experiment Tracking — cada corrida de entrenamiento
model ExperimentRun {
  id           String   @id @default(uuid())
  status       String   @default("running") // running, completed, failed
  bestModel    String?
  nCustomers   Int?
  nFeatures    Int?
  churnRate    Float?
  accuracy     Float?
  precision    Float?
  recall       Float?
  f1           Float?
  rocAuc       Float?
  targetsMet   Boolean?
  metrics      String?  // JSON con comparativa de todos los modelos
  parameters   String?  // JSON con hiperparámetros
  log          String?
  modelPath    String?
  createdAt    DateTime @default(now())
  completedAt  DateTime?

  @@index([status])
  @@index([createdAt])
  @@map("experiment_runs")
}

/// Feature Store — catálogo de features del ML pipeline
model FeatureDefinition {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  category    String   @default("behavioral") // behavioral, monetary, temporal, demographic, channel
  dataType    String   @default("numeric")    // numeric, categorical, boolean
  source      String?  // "train.py", "manual"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  values      FeatureValue[]

  @@map("feature_definitions")
}

/// Feature Value — valor calculado de una feature para un cliente
model FeatureValue {
  id         String   @id @default(uuid())
  feature    FeatureDefinition @relation(fields: [featureId], references: [id], onDelete: Cascade)
  featureId  String
  clienteId  String
  value      String   // valor serializado (float como string para precisión)
  computedAt DateTime @default(now())

  @@unique([featureId, clienteId])
  @@index([clienteId])
  @@index([featureId])
  @@map("feature_values")
}

/// A/B experimento de modelos o estrategias
model ExperimentTest {
  id            String        @id @default(uuid())
  name          String
  description   String?
  status        String        @default("draft")
  targetMetric  String        @default("roc_auc")
  createdBy     String?
  createdAt     DateTime      @default(now())
  startedAt     DateTime?
  endedAt       DateTime?
  variants      TestVariant[]
  @@index([status])
  @@map("experiment_tests")
}

model TestVariant {
  id            String         @id @default(uuid())
  experiment    ExperimentTest @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  experimentId  String
  name          String
  description   String?
  trafficPct    Float          @default(50.0)
  config        String?
  assignments   TestAssign[]
  createdAt     DateTime       @default(now())
  @@map("test_variants")
}

model TestAssign {
  id          String      @id @default(uuid())
  variant     TestVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId   String
  clienteId   String
  assignedAt  DateTime    @default(now())
  converted   Boolean?
  convertedAt DateTime?
  @@unique([variantId, clienteId])
  @@index([clienteId])
  @@map("test_assigns")
}