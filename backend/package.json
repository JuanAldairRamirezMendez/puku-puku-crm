{
  "name": "puku-puku-crm-backend",
  "version": "1.0.0",
  "description": "API REST del Panel de Atención Unificado — Puku Puku (APF2/APF3, Innovación y Transformación Digital, UTP 2026-1)",
  "main": "src/server.js",
  "type": "commonjs",
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "testMatch": [
      "**/*.test.js"
    ],
    "clearMocks": true,
    "resetMocks": false
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "dev:ts": "tsx watch src/server.ts",
    "start": "node src/server.js",
    "build": "tsc",
    "start:ts": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "seed:apf3": "node prisma/seed-apf3.js",
    "ml:install": "python3 -m pip install -r ml/requirements.txt --quiet 2>/dev/null || python -m pip install -r ml/requirements.txt --quiet 2>/dev/null || echo '[ML] pip no disponible, instala manualmente: pip install -r ml/requirements.txt'",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.1",
    "jest": "^30.4.2",
    "nodemon": "^3.1.4",
    "prisma": "^5.20.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
